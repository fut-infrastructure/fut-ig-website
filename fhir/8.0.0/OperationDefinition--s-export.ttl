  fhir:version [ fhir:v "8.0.0"] ; # 
  fhir:name [ fhir:v "export"] ; # 
  fhir:title [ fhir:v "FHIR Bulk Data System Level Export"] ; # 
  fhir:status [ fhir:v "active"] ; # 
  fhir:kind [ fhir:v "operation"] ; # 
  fhir:date [ fhir:v "2026-01-27T10:56:04+00:00"^^xsd:dateTime] ; # 
