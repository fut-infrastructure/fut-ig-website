       fhir:system [ fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ] ;
       fhir:code [ fhir:v "DK" ] ;
       fhir:display [ fhir:v "Denmark" ]
     ] )
  ] ) ; # 
